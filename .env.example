NODE_ENV=production
PORT=3000
BASE_URL=https://api.payledger.io

# Database & Redis
DATABASE_URL=postgresql://user:pass@host:5432/payledger?sslmode=require
REDIS_URL=redis://:password@host:6379

# JWT
JWT_SECRET=<64-char random hex>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7

# Webhook Secret Encryption (32-byte hex string = 64 hex characters)
WEBHOOK_SECRET_ENCRYPTION_KEY=<64-char random hex>

# Nomba API
NOMBA_CLIENT_ID=your-client-id
NOMBA_CLIENT_SECRET=your-client-secret
NOMBA_ACCOUNT_ID=your-parent-account-id
NOMBA_BASE_URL=https://api.nomba.com

# Logging
LOG_LEVEL=info
